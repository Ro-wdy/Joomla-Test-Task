<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="content" method="upgrade">
	<name>plg_content_joomlaorg</name>
	<author>Joomla Organisation</author>
	<creationDate>March 2026</creationDate>
	<copyright>Copyright (C) 2026 Joomla Organisation. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later</license>
	<authorEmail>admin@joomla.org</authorEmail>
	<authorUrl>www.joomla.org</authorUrl>
	<version>1.0.0</version>
	<description>PLG_CONTENT_JOOMLAORG_XML_DESCRIPTION</description>

	<namespace path="src">Joomla\Plugin\Content\Joomlaorg</namespace>

	<files>
		<folder>services</folder>
		<folder>src</folder>
	</files>

    <languages folder="language">
        <language tag="en-GB">en-GB/plg_content_joomlaorg.ini</language>
        <language tag="en-GB">en-GB/plg_content_joomlaorg.sys.ini</language>
    </languages>

    <media destination="plg_content_joomlaorg" folder="media">
        <folder>js</folder>
    </media>

	<config>
		<fields name="params">
			<fieldset name="basic">
				<field
					name="default_title_text"
					type="text"
					label="PLG_CONTENT_JOOMLAORG_PARAM_DEFAULT_TITLE_LABEL"
					description="PLG_CONTENT_JOOMLAORG_PARAM_DEFAULT_TITLE_DESC"
					default="Default Article Title from Plugin"
					filter="string"
				/>
			</fieldset>
		</fields>
	</config>
</extension>
